PORT=4000
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=1h

# Standard PostgreSQL connection string (used by the app via @prisma/adapter-pg)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Used by Prisma CLI for migrations (prisma migrate dev, prisma db push, etc.)
# Can be the same as DATABASE_URL for a direct connection
MIGRATE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
